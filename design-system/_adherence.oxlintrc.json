{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/feedback/**",
              "components/game/**",
              "components/navigation/**",
              "ui_kits/xuxu-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Baloo 2|Nunito))/i]",
        "message": "Font not provided by the design system. Available: Baloo 2, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:emoji|label|tone|earned|size|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: emoji, label, tone, earned, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|gold|streak|violet|info|life)$/]",
        "message": "<Badge> tone must be one of 'green' | 'gold' | 'streak' | 'violet' | 'info' | 'life'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|icon|activeBg|key|ref|className|style|children)$/]",
        "message": "<NavTab> doesn't accept that prop. Declared props: id, icon, activeBg."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|block|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, block, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|streak|gold|white|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'streak' | 'gold' | 'white' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, tone, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|indigo|violet|gold|streak|neutral)$/]",
        "message": "<Chip> tone must be one of 'green' | 'indigo' | 'violet' | 'gold' | 'streak' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|bg|color|radius|fontSize|style|key|ref|className|style|children)$/]",
        "message": "<IconTile> doesn't accept that prop. Declared props: children, size, bg, color, radius, fontSize, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Lesson'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|ageGroup|icon|bgColor|xp|key|ref|className|style|children)$/]",
        "message": "<Lesson> doesn't accept that prop. Declared props: title, subtitle, ageGroup, icon, bgColor, xp."
      },
      {
        "selector": "JSXOpeningElement[name.name='Lesson'] > JSXAttribute[name.name='ageGroup'] > Literal[value!=/^(?:6-8|9-12|13-16)$/]",
        "message": "<Lesson> ageGroup must be one of '6-8' | '9-12' | '13-16'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|height|tone|track|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, height, tone, track, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|streak|gems|onDark)$/]",
        "message": "<ProgressBar> tone must be one of 'green' | 'streak' | 'gems' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuizOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|children|state|onClick|style|key|ref|className|style|children)$/]",
        "message": "<QuizOption> doesn't accept that prop. Declared props: index, children, state, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuizOption'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:idle|selected|correct|wrong|dimmed)$/]",
        "message": "<QuizOption> state must be one of 'idle' | 'selected' | 'correct' | 'wrong' | 'dimmed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|value|icon|iconColor|bg|border|style|key|ref|className|style|children)$/]",
        "message": "<StatPill> doesn't accept that prop. Declared props: kind, value, icon, iconColor, bg, border, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:streak|xu|xp)$/]",
        "message": "<StatPill> kind must be one of 'streak' | 'xu' | 'xp'."
      },
      {
        "selector": "JSXOpeningElement[name.name='XuCoin'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|style|key|ref|className|style|children)$/]",
        "message": "<XuCoin> doesn't accept that prop. Declared props: size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='XuXuMascot'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|mood|float|style|key|ref|className|style|children)$/]",
        "message": "<XuXuMascot> doesn't accept that prop. Declared props: size, mood, float, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='XuXuMascot'] > JSXAttribute[name.name='mood'] > Literal[value!=/^(?:happy|excited|sad)$/]",
        "message": "<XuXuMascot> mood must be one of 'happy' | 'excited' | 'sad'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
